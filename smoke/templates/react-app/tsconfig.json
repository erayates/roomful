{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@roomful/core": [
        "../../../packages/core/dist/index.d.ts",
        "./node_modules/@roomful/core/dist/index.d.ts"
      ],
      "@roomful/react": [
        "../../../packages/react/dist/index.d.ts",
        "./node_modules/@roomful/react/dist/index.d.ts"
      ]
    },
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": ["src"]
}
