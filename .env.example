# Roomful relay — self-host configuration.
#
# Copy to .env and adjust:  cp .env.example .env
# docker compose reads .env for you. Every value has a safe default, so an empty
# .env runs a working relay; uncomment a line only to override it.
#
# Leave optional values COMMENTED to keep them unset — an empty value (e.g. `FOO=`)
# is not the same as "unset" and may be rejected.

# Port the relay listens on (host and container).
PORT=8787

# Maximum concurrent WebSocket connections across all rooms.
MAX_CONNECTIONS=1000

# --- Production hardening (all optional) ---

# Hard per-room peer cap, applied on top of any client-requested maxPeers.
# ROOMFUL_MAX_ROOM_SIZE=50

# Maximum distinct rooms this relay instance will host.
# ROOMFUL_MAX_ROOMS=1000

# Per-peer message rate limit: at most ROOMFUL_MESSAGE_RATE_LIMIT messages per
# ROOMFUL_MESSAGE_RATE_INTERVAL_MS. Set BOTH together to enable rate limiting.
# ROOMFUL_MESSAGE_RATE_LIMIT=240
# ROOMFUL_MESSAGE_RATE_INTERVAL_MS=60000

# Allowed browser origin for CORS and WebSocket upgrades ('*' allows any).
# Leave unset to allow all origins.
# ROOMFUL_CORS_ORIGIN=https://app.example.com

# HS256 JWT secret enabling built-in token auth. When set, peers must present a
# valid token signed with this secret. Keep it out of version control.
# ROOMFUL_AUTH_SECRET=replace-with-a-long-random-secret

# --- Multi-instance coordination (experimental) ---

# Redis URL for coordinating rooms across relay instances. When set, also start
# the bundled Redis with:  docker compose --profile redis up
# ROOMFUL_REDIS_URL=redis://redis:6379/0
