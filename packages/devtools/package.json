{
  "name": "@roomful/devtools",
  "version": "1.0.1",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/build-extension.mjs",
    "build:library": "tsc -p tsconfig.json",
    "build:extension": "node ./scripts/build-extension.mjs",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "test:types": "tsd --files test-d/**/*.test-d.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist coverage",
    "test:watch": "vitest --config ../../vitest.package.config.ts"
  },
  "publishConfig": {
    "access": "public"
  }
}
