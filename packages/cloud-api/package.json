{
  "name": "@roomful/cloud-api",
  "version": "0.1.0-alpha.1",
  "description": "Roomful Cloud API — project management, API keys, usage metering, and dashboard backend.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erayates/roomful.git",
    "directory": "packages/cloud-api"
  },
  "bugs": {
    "url": "https://github.com/erayates/roomful/issues"
  },
  "homepage": "https://github.com/erayates/roomful/tree/main/packages/cloud-api#readme",
  "keywords": [
    "roomful",
    "cloud",
    "api",
    "realtime"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --config ../../vitest.package.config.ts --fileParallelism=false",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.3.3"
  }
}
