{
  "name": "@flockjs/relay",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --config ../../vitest.package.config.ts --fileParallelism=false",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "benchmark:redis": "vitest bench --config ../../vitest.package.config.ts src/relay-redis-latency.bench.ts",
    "clean": "rimraf dist coverage",
    "test:watch": "vitest --config ../../vitest.package.config.ts --fileParallelism=false"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.2",
    "ioredis": "^5.10.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
