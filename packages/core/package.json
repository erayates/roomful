{
  "name": "@flockjs/core",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src \"integration/**/*.test.ts\" --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:engines": "vitest run --config vitest.engines.config.ts --coverage.enabled=false",
    "test:engines:coverage": "vitest run --config vitest.engines.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.integration.json --noEmit",
    "clean": "rimraf dist coverage",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29"
  }
}
