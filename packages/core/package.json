{
  "name": "@roomful/core",
  "description": "Framework-agnostic SDK for realtime collaboration — presence, cursors, shared state, awareness, events, viewport, locking, pointer, comments, and history.",
  "version": "1.4.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapter-runtime": {
      "types": "./dist/adapter-runtime.d.ts",
      "import": "./dist/adapter-runtime.js",
      "default": "./dist/adapter-runtime.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src \"integration/**/*.test.ts\" --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:types": "tsd --files test-d/**/*.test-d.ts",
    "test:engines": "vitest run --config vitest.engines.config.ts --coverage.enabled=false",
    "test:engines:coverage": "vitest run --config vitest.engines.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.integration.json --noEmit",
    "clean": "rimraf dist coverage",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@roomful/devtools": "workspace:*",
    "@types/node": "^25.3.3",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29"
  }
}
