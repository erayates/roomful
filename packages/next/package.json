{
  "name": "@roomful/next",
  "description": "Next.js server-side auth-token helpers for Roomful realtime rooms.",
  "version": "1.1.1",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:types": "tsd --files test-d/**/*.test-d.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist coverage",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@roomful/core": "workspace:*"
  },
  "devDependencies": {
    "@roomful/core": "workspace:*",
    "@roomful/relay": "workspace:*",
    "@types/node": "^25.3.3",
    "tsd": "^0.33.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
