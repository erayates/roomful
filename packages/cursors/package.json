{
  "name": "@roomful/cursors",
  "version": "1.0.0-beta.3",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build-storybook": "storybook build -c .storybook --output-dir storybook-static",
    "lint": "eslint src stories .storybook --max-warnings 0",
    "storybook": "storybook dev -p 6006 -c .storybook",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "test:types": "tsd --files test-d/**/*.test-d.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.storybook.json --noEmit",
    "clean": "rimraf dist coverage storybook-static",
    "test:watch": "vitest --config ../../vitest.package.config.ts"
  },
  "dependencies": {
    "@roomful/core": "workspace:*",
    "@roomful/react": "workspace:*"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "storybook": "^10.2.17",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
