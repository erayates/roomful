{
  "name": "flockjs",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test --filter=./packages/*",
    "test:types": "turbo run test:types --filter=./packages/*",
    "test:integration": "pnpm --filter @flockjs/core build && playwright test --config playwright.config.ts",
    "test:integration:react": "pnpm --filter @flockjs/core build && pnpm --filter @flockjs/react build && playwright test --config playwright.react.config.ts",
    "test:watch": "turbo run test:watch --filter=./packages/* --parallel",
    "typecheck": "turbo run typecheck",
    "typecheck:root": "tsc --noEmit -p tsconfig.json",
    "typecheck:all": "pnpm run typecheck && pnpm run typecheck:root",
    "verify:package-types": "node scripts/verify-package-types.mjs",
    "quality": "pnpm run typecheck:all && pnpm run lint",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "commitlint": "commitlint",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "release:status": "changeset status --verbose",
    "verify:tsconfig-extends": "node scripts/verify-tsconfig-extends.mjs",
    "prepare": "husky",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.22.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsd": "^0.33.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
