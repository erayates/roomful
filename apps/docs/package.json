{
  "name": "@roomful/app-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/docs/prepare-docs-site.mjs && astro dev",
    "build": "node ../../scripts/docs/prepare-docs-site.mjs && astro build",
    "preview": "node ../../scripts/docs/prepare-docs-site.mjs && astro preview",
    "lint": "astro sync && eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "test": "node ../../scripts/docs/validate-doc-snippets.mjs",
    "typecheck": "node ../../scripts/docs/prepare-docs-site.mjs && astro check",
    "clean": "rimraf dist .astro"
  },
  "dependencies": {
    "@roomful/core": "workspace:*",
    "@roomful/cursors": "workspace:*",
    "@roomful/devtools": "workspace:*",
    "@roomful/react": "workspace:*",
    "@roomful/relay": "workspace:*",
    "@roomful/svelte": "workspace:*",
    "@roomful/vue": "workspace:*"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.4",
    "@astrojs/react": "5.0.0",
    "@astrojs/starlight": "0.37.7",
    "@astrojs/starlight-docsearch": "0.6.1",
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/space-grotesk": "5.2.10",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "astro": "5.18.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "5.8.2",
    "zod": "3.25.76"
  }
}
