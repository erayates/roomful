---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Primitives from '../components/Primitives.astro';
import CodeSection from '../components/CodeSection.astro';
import Transports from '../components/Transports.astro';
import Stats from '../components/Stats.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import MotionRoot from '../components/MotionRoot.astro';
---

<Base
  title="Roomful — Realtime collaboration primitives for product teams"
  description="Presence, multiplayer cursors, shared state, and awareness over WebRTC, BroadcastChannel, or your own relay. First-class React, Vue, and Svelte bindings."
>
  <Nav />
  <main>
    <Hero />
    <Marquee />
    <Primitives />
    <CodeSection />
    <Transports />
    <Stats />
    <FinalCta />
  </main>
  <Footer />
  <MotionRoot />
</Base>
